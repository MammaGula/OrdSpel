@page "/game/{Code}/result"
@page "/gameresult"
@page "/game/{Code}/gameresult"
@using OrdSpel.Shared.DTOs
@using OrdSpel.Shared.Enums
@inject OrdSpel.UI.Services.GameService GameService
@inject NavigationManager Navigation

<div class="container mt-4">
    @if (_isLoading)
    {
        <p id="gameResultLoading" class="text-muted">Laddar resultat...</p>
    }
    else if (_error is not null)
    {
        <div id="gameResultError" class="alert alert-danger">@_error</div>
        <button id="gameResultBackButton" class="btn btn-outline-secondary" @onclick="BackToGame">Tillbaka</button>
    }
    else if (_result is null)
    {
        <div id="gameResultError" class="alert alert-danger">Kunde inte ladda resultatet.</div>
        <button id="gameResultBackButton" class="btn btn-outline-secondary" @onclick="BackToGame">Tillbaka</button>
    }
    else
    {
        <h2 id="gameResultTitle">Spelslut & resultat</h2>

        <div class="mb-3">
            @if (string.IsNullOrWhiteSpace(_result.WinnerUserId))
            {
                <div id="gameResultWinner" class="alert alert-info">Oavgjort!</div>
            }
            else
            {
                <div id="gameResultWinner" class="alert alert-success">Vinnare: @_result.WinnerUserId</div>
            }
        </div>

        <h5 id="gameResultScoreboardTitle">Poängtabell</h5>
        <ul id="gameResultScoreboard" class="list-group" style="max-width: 420px;">
            @foreach (var player in _result.Players.OrderBy(p => p.PlayerOrder))
            {
                <li class="list-group-item d-flex justify-content-between align-items-center" id="gameResultPlayer-@player.PlayerOrder">
                    <span>Spelare @player.PlayerOrder</span>
                    <span class="badge bg-primary rounded-pill">@player.TotalScore p</span>
                </li>
            }
        </ul>

        <div class="mt-4">
            <button id="gameResultBackButton" class="btn btn-primary" @onclick="BackToGame">Tillbaka till spelet</button>
        </div>
    }
</div>

@code {
    [Parameter]
    public string? Code { get; set; }

    private GameResultDto? _result;
    private bool _isLoading = true;
    private string? _error;

    protected override async Task OnParametersSetAsync()
    {
        if (string.IsNullOrWhiteSpace(Code))
        {
            _error = "Game code saknas.";
            _isLoading = false;
            return;
        }

        _isLoading = true;
        _error = null;

        try
        {
            _result = await GameService.GetGameResultAsync(Code);
            if (_result is not null && _result.Status != GameStatus.GameFinished)
            {
                _error = "Spelet är inte avslutat ännu.";
            }
        }
        catch (HttpRequestException)
        {
            _error = "Kunde inte hämta resultat från servern.";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void BackToGame()
    {
        if (!string.IsNullOrWhiteSpace(Code))
        {
            Navigation.NavigateTo($"/game/{Uri.EscapeDataString(Code)}");
        }
        else
        {
            Navigation.NavigateTo("/game");
        }
    }
}
